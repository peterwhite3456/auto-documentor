{
  "name": "auto-documentor",
  "version": "0.1.0",
  "description": "CLI tool to scan codebases and generate documentation with OpenAI",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "auto-documentor": "dist/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}